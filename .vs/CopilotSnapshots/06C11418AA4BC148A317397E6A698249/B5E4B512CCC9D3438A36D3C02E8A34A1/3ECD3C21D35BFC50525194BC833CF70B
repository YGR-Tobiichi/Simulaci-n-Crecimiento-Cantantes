<Window x:Class="U5PSC24100562.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:U5PSC24100562"
        mc:Ignorable="d"
        Title="MainWindow" Height="650" Width="1100" Background="#071226">
    <Window.Resources>
        <!-- Palette -->
        <SolidColorBrush x:Key="BackgroundBrush" Color="#071226"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#0F2233"/>
        <SolidColorBrush x:Key="CardBrush" Color="#162A3C"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#7C5CFF"/>
        <SolidColorBrush x:Key="AccentBrushLight" Color="#9B88FF"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#2A3B48"/>
        <SolidColorBrush x:Key="LightText" Color="#E8F0FF"/>
        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="6" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="8,2"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CardTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource LightText}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Opacity" Value="0.85" />
            <Setter Property="FontWeight" Value="Normal" />
        </Style>
        <Style x:Key="CardValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource LightText}" />
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource BackgroundBrush}" Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="72"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PanelBrush}" CornerRadius="10" Padding="12" Margin="0,0,0,10">
            <DockPanel LastChildFill="True" VerticalAlignment="Center">
                <!-- Identity -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center" spacing="12">
                    <!-- Avatar -->
                    <Border Width="48" Height="48" CornerRadius="24" Background="{StaticResource AccentBrush}" VerticalAlignment="Center">
                        <TextBlock Text="A" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                        <TextBlock Text="Artista: Nombre Artístico" Foreground="{StaticResource LightText}" FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock Text="Semana: 3" Foreground="{StaticResource LightText}" FontSize="12" Opacity="0.9"/>
                    </StackPanel>
                </StackPanel>

                <!-- Right side placeholder for status/icons -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center" Spacing="10">
                    <TextBlock Text="Estado: Activo" Foreground="{StaticResource LightText}" VerticalAlignment="Center" Opacity="0.9"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Body -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Metrics column -->
            <StackPanel Grid.Column="0" Orientation="Vertical" Spacing="12">
                <Border Background="{StaticResource CardBrush}" CornerRadius="10" Padding="12">
                    <StackPanel>
                        <TextBlock Text="Métricas clave" Foreground="{StaticResource LightText}" FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock Text="Resumen en tiempo real" Foreground="{StaticResource LightText}" Opacity="0.8" FontSize="12"/>
                    </StackPanel>
                </Border>

                <!-- Followers Card -->
                <Border Background="{StaticResource CardBrush}" CornerRadius="10" Padding="12">
                    <StackPanel>
                        <TextBlock Text="Seguidores" Style="{StaticResource CardTitle}" />
                        <TextBlock Text="1,254,320" Style="{StaticResource CardValue}" Margin="0,6,0,0" />
                    </StackPanel>
                </Border>

                <!-- Engagement Card -->
                <Border Background="{StaticResource CardBrush}" CornerRadius="10" Padding="12">
                    <StackPanel>
                        <TextBlock Text="Engagement" Style="{StaticResource CardTitle}" />
                        <ProgressBar Minimum="0" Maximum="100" Value="68" Height="18" Margin="0,8,0,6" Foreground="{StaticResource AccentBrush}" Background="#0B2230" />
                        <TextBlock Text="68% activo" Foreground="{StaticResource LightText}" Opacity="0.9" FontSize="12"/>
                    </StackPanel>
                </Border>

                <!-- Fatigue Card -->
                <Border Background="{StaticResource CardBrush}" CornerRadius="10" Padding="12">
                    <StackPanel>
                        <TextBlock Text="Fatiga" Style="{StaticResource CardTitle}" />
                        <!-- Simple visual indicator -->
                        <Grid Margin="0,8,0,6">
                            <Border Background="#0B2230" CornerRadius="6" Height="14" VerticalAlignment="Center">
                                <Rectangle Fill="{StaticResource AccentBrushLight}" Width="120" Height="14" RadiusX="6" RadiusY="6"/>
                            </Border>
                            <TextBlock Text="Moderada" Foreground="{StaticResource LightText}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="12"/>
                        </Grid>
                        <TextBlock Text="Nivel de fatiga actual" Foreground="{StaticResource LightText}" Opacity="0.9" FontSize="12"/>
                    </StackPanel>
                </Border>

                <Border Background="Transparent" />
            </StackPanel>

            <!-- Center: Main visualization -->
            <Border Grid.Column="1" Background="{StaticResource PanelBrush}" CornerRadius="10" Padding="14" Margin="12,0" >
                <Grid>
                    <StackPanel>
                        <TextBlock Text="Evolución" Foreground="{StaticResource LightText}" FontSize="16" FontWeight="SemiBold" />
                        <TextBlock Text="Visualizador principal - gráficos de crecimiento" Foreground="{StaticResource LightText}" Opacity="0.8" FontSize="12" Margin="0,4,0,12"/>

                        <!-- Placeholder para gráfico -->
                        <Border Background="#0B2B40" CornerRadius="8" Height="420" HorizontalAlignment="Stretch" VerticalAlignment="Top">
                            <Grid>
                                <TextBlock Text="[ Gráfica de crecimiento a lo largo del tiempo ]" Foreground="{StaticResource LightText}" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.6"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Right: Logs and Controls -->
            <StackPanel Grid.Column="2" Orientation="Vertical" Spacing="12">
                <!-- Logs -->
                <Border Background="{StaticResource CardBrush}" CornerRadius="10" Padding="12" Height="360">
                    <StackPanel>
                        <TextBlock Text="Registro de eventos" Foreground="{StaticResource LightText}" FontSize="14" FontWeight="SemiBold" />
                        <ListBox Background="#0B2230" BorderThickness="0" Foreground="{StaticResource LightText}" Margin="0,8,0,0">
                            <ListBoxItem>Inicio de simulación: ciclo 1 - éxito</ListBoxItem>
                            <ListBoxItem>Ciclo 2: publicación viral - +12k seguidores</ListBoxItem>
                            <ListBoxItem>Ciclo 3: ligera caída de engagement</ListBoxItem>
                        </ListBox>
                    </StackPanel>
                </Border>

                <!-- Controls -->
                <Border Background="{StaticResource CardBrush}" CornerRadius="10" Padding="12">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Controles" Foreground="{StaticResource LightText}" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                            <Button Style="{StaticResource AccentButton}" Width="110">Avanzar ciclo</Button>
                            <Button Background="#2B3F55" Foreground="{StaticResource LightText}" Width="90" Margin="6">Pausa</Button>
                            <Button Background="#2B3F55" Foreground="{StaticResource LightText}" Width="90" Margin="6">Reiniciar</Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Background="Transparent" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
