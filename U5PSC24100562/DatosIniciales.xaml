<Window x:Name="ventAdi" x:Class="U5PSC24100562.DatosIniciales"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:U5PSC24100562"
        mc:Ignorable="d"
        Title="DatosIniciales" Height="400" Width="400" WindowStyle="ToolWindow">
    <Window.Resources>
        <!-- Palette -->
        <SolidColorBrush x:Key="BackgroundBrush" Color="#071226"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#0F2233"/>
        <SolidColorBrush x:Key="CardBrush" Color="#162A3C"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#7C5CFF"/>
        <SolidColorBrush x:Key="AccentBrushLight" Color="#9B88FF"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#2A3B48"/>
        <SolidColorBrush x:Key="LightText" Color="#E8F0FF"/>
        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="6" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="8,2"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CardTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource LightText}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Opacity" Value="0.85" />
            <Setter Property="FontWeight" Value="Normal" />
        </Style>
        <Style x:Key="CardValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource LightText}" />
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
    </Window.Resources>
    <Window.Background>
        <ImageBrush ImageSource="/Images/abstract-fluid-liquid-dark-colorful-hd-wallpaper-preview.jpg"/>
    </Window.Background>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="5" Margin="5" Background="{StaticResource PanelBrush}" Padding="20">
            <TextBlock Text="Datos iniciales para la simulación" Foreground="{StaticResource LightText}" FontSize="19" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
        </Border>

        <Border Grid.Row="1" CornerRadius="5" Margin="5" Padding="5" Background="{DynamicResource PanelBrush}">
            <StackPanel VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
                    <TextBlock Text="Seguidores iniciales:" Style="{StaticResource CardTitle}" VerticalAlignment="Center" Padding="5"/>
                    <TextBox x:Name="txtSegudores" Width="100" Background="{StaticResource CardBrush}" Foreground="{StaticResource LightText}" BorderThickness="0" Padding="6"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
                    <TextBlock Text="Número de semanas a simular:" Style="{StaticResource CardTitle}" VerticalAlignment="Center" Padding="5"/>
                    <TextBox x:Name="txtTiempoSimulacion" Width="100" Background="{StaticResource CardBrush}" Foreground="{StaticResource LightText}" BorderThickness="0" Padding="6"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
                    <TextBlock Text="Nombre del artista:" Style="{StaticResource CardTitle}" VerticalAlignment="Center" Padding="5"/>
                    <TextBox x:Name="txtNombreArtista" Width="100" Background="{StaticResource CardBrush}" Foreground="{StaticResource LightText}" BorderThickness="0" Padding="6"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
                    <TextBlock Text="Intervalo de lanzamiento (semanas):" Style="{StaticResource CardTitle}" VerticalAlignment="Center" Padding="5"/>
                    <ComboBox x:Name="cbIntervaloLanzamiento" Width="100" BorderThickness="0" Padding="6">
                        <ComboBoxItem Content="1"/>
                        <ComboBoxItem Content="2"/>
                        <ComboBoxItem Content="3"/>
                        <ComboBoxItem Content="4"/>
                    </ComboBox>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
                    <TextBlock Text="Valor de marketing:" Style="{StaticResource CardTitle}" VerticalAlignment="Center" Padding="5"/>
                    <ComboBox x:Name="cbMarketing" Width="100" BorderThickness="0" Padding="6">
                        <ComboBoxItem Content="1.0"/>
                        <ComboBoxItem Content="1.5"/>
                        <ComboBoxItem Content="2.0"/>
                    </ComboBox>
                </StackPanel>
                <Button x:Name="btnIniciarSimulacion" Content="Iniciar Simulación" Style="{StaticResource AccentButton}" Click="btnIniciarSimulacion_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
