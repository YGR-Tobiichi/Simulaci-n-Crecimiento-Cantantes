<Window x:Class="U5PSC24100562.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:U5PSC24100562"
        mc:Ignorable="d"
        Title="MainWindow" Height="670" Width="1125" WindowStyle="ToolWindow">
    <Window.Resources>
        <!-- Palette -->
        <SolidColorBrush x:Key="BackgroundBrush" Color="#071226"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#0F2233"/>
        <SolidColorBrush x:Key="CardBrush" Color="#162A3C"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#7C5CFF"/>
        <SolidColorBrush x:Key="AccentBrushLight" Color="#9B88FF"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#2A3B48"/>
        <SolidColorBrush x:Key="LightText" Color="#E8F0FF"/>
        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="6" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="8,2"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CardTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource LightText}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Opacity" Value="0.85" />
            <Setter Property="FontWeight" Value="Normal" />
        </Style>
        <Style x:Key="CardValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource LightText}" />
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
    </Window.Resources>
    <Window.Background>
        <ImageBrush ImageSource="/Images/FondoBonitoParaSim.jpg"/>
    </Window.Background>

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="599*"/>
            <ColumnDefinition Width="477*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="72"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PanelBrush}" CornerRadius="10" Padding="5,0,0,0" Margin="0,0,0,10" Grid.ColumnSpan="2">
            <DockPanel LastChildFill="True" VerticalAlignment="Center">
                <!-- Identity -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <!-- Avatar -->
                    <Border Width="48" Height="48" CornerRadius="24" Background="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="0,0,12,0">
                        <Image Source="/Images/Yukari.png" ClipToBounds="True" />
                        <!--<TextBlock Text="A" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>-->
                    </Border>
                    <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Artista: " Foreground="{StaticResource LightText}" FontSize="14" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding nombreArtista}" Foreground="{StaticResource LightText}" FontSize="14" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Semana:" Foreground="{StaticResource LightText}" FontSize="12" Opacity="0.9"/>
                            <TextBlock Text="{Binding semana}" Foreground="{StaticResource LightText}" FontSize="12" Opacity="0.9" Margin="6,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Right side placeholder for status/icons -->
                <StackPanel DockPanel.Dock="Right" VerticalAlignment="Center" Margin="15,0,0,0">

                    <!--<Image Source="/Images/FondoBonitoParaSim.jpg" Margin="0,0,6,0"/>-->
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Body -->
        <Grid Grid.Row="1" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Metrics column -->
            <StackPanel Grid.Column="0" Orientation="Vertical" HorizontalAlignment="Left" Width="280">
                <Border Background="{StaticResource CardBrush}" CornerRadius="10" Padding="12" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Métricas clave" Foreground="{StaticResource LightText}" FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock Text="Resumen en tiempo real" Foreground="{StaticResource LightText}" Opacity="0.8" FontSize="12"/>
                    </StackPanel>
                </Border>

                <!-- Followers Card -->
                <Border Background="{StaticResource CardBrush}" CornerRadius="10" Padding="12" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Seguidores" Style="{StaticResource CardTitle}" />
                        <TextBlock Text="{Binding seguidores}" Style="{StaticResource CardValue}" Margin="0,6,0,0" />
                    </StackPanel>
                </Border>

                <!-- Engagement Card -->
                <Border Background="{StaticResource CardBrush}" CornerRadius="10" Padding="12" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Engagement" Style="{StaticResource CardTitle}" />
                        <ProgressBar Minimum="0" Maximum="1" Value="{Binding engagement}" Height="18" Margin="0,8,0,6" Foreground="{StaticResource AccentBrush}" Background="#0B2230" />
                        <TextBlock Text="{Binding engagement, StringFormat={}{0:P0}}" Foreground="{StaticResource LightText}" Opacity="0.9" FontSize="12"/>
                    </StackPanel>
                </Border>

                <!-- Fatigue Card -->
                <Border Background="{StaticResource CardBrush}" CornerRadius="10" Padding="12" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Fatiga" Style="{StaticResource CardTitle}" />
                        <!-- Simple visual indicator -->
                        <ProgressBar Minimum="0" Maximum="1" Value="{Binding fatiga}" Height="18" Margin="0,8,0,6" Foreground="{StaticResource AccentBrush}" Background="#0B2230" />
                        <TextBlock Text="{Binding fatiga, StringFormat={}{0:P0}}" Foreground="{StaticResource LightText}" Opacity="0.9" FontSize="12"/>

                        <Grid Margin="0,2,0,0">
                            <TextBlock Text="Nivel de fatiga actual" Foreground="{StaticResource LightText}" Opacity="0.9" FontSize="12"/>

                        </Grid>

                    </StackPanel>
                </Border>

                <Border Background="Transparent" />
            </StackPanel>

            <!-- Center: Main visualization -->
            <Border Grid.Column="1" Background="{StaticResource PanelBrush}" CornerRadius="10" Padding="14" Margin="9,0,0,0" HorizontalAlignment="Left" Width="448" Height="538" VerticalAlignment="Bottom" >
                <Grid>
                    <StackPanel>
                        <TextBlock Text="Evolución" Foreground="{StaticResource LightText}" FontSize="16" FontWeight="SemiBold" />
                        <TextBlock Text="Visualizador principal - gráficos de crecimiento" Foreground="{StaticResource LightText}" Opacity="0.8" FontSize="12" Margin="0,4,0,12"/>

                        <!-- Placeholder para gráfico -->
                        <Border Background="#0B2B40" CornerRadius="8" Height="420" HorizontalAlignment="Stretch" VerticalAlignment="Top" Margin="0,0,0,0">
                            <Grid>
                                <TextBlock Text="[ Gráfica de crecimiento a lo largo del tiempo ]" Foreground="{StaticResource LightText}" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.6"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Right: Logs and Controls -->
            <StackPanel Grid.Column="1" Orientation="Vertical" Grid.ColumnSpan="2" Margin="466,0,0,0" HorizontalAlignment="Left" Width="340">
                <!-- Logs -->
                <Border Background="{StaticResource CardBrush}" CornerRadius="10" Padding="12" Height="360" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Registro de eventos" Foreground="{StaticResource LightText}" FontSize="14" FontWeight="SemiBold" />
                        <ListBox x:Name="lbLogEventos" Background="#0B2230" BorderThickness="0" Foreground="{StaticResource LightText}" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Controls -->
                <Border Background="{StaticResource CardBrush}" CornerRadius="10" Padding="12">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Controles" Foreground="{StaticResource LightText}" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                            <Button x:Name="btnAvanzarCiclo" Style="{StaticResource AccentButton}" Width="110" Content="Avanzar ciclo" Click="btnAvanzarCiclo_Click" IsEnabled="{Binding iniciar}"/>
                            <Button x:Name="btnPausar" Background="#2B3F55" Foreground="{StaticResource LightText}" Width="90" Margin="6" Content="Pausa" IsEnabled="{Binding iniciar}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Background="Transparent" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
